generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  NEW_LEAD  @map("new_lead")
  CONTACTED @map("contacted")
  BOOKED    @map("booked")
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  LOST      @map("lost")
}

enum PreferredLanguage {
  EN @map("en")
  ZH @map("zh")
}

enum AppointmentStatus {
  SCHEDULED @map("scheduled")
  CONFIRMED @map("confirmed")
  COMPLETED @map("completed")
  CANCELED  @map("canceled")
  NO_SHOW   @map("no_show")
}

enum MessageChannel {
  SMS   @map("sms")
  EMAIL @map("email")
}

enum MessageDirection {
  OUTBOUND @map("outbound")
}

enum MessageStatus {
  DRAFT  @map("draft")
  QUEUED @map("queued")
  SENT   @map("sent")
  FAILED @map("failed")
}

enum WorkflowTrigger {
  LEAD_CREATED           @map("lead_created")
  LEAD_NOT_CONTACTED_24H @map("lead_not_contacted_24h")
  APPOINTMENT_BOOKED     @map("appointment_booked")
  APPOINTMENT_REMINDER   @map("appointment_reminder")
  APPOINTMENT_COMPLETED  @map("appointment_completed")
  CUSTOMER_INACTIVE_30D  @map("customer_inactive_30d")
}

enum WorkflowAction {
  SEND_MESSAGE           @map("send_message")
  CREATE_TASK            @map("create_task")
  UPDATE_CUSTOMER_STATUS @map("update_customer_status")
  ASSIGN_OWNER           @map("assign_owner")
  REQUEST_REVIEW         @map("request_review")
}

enum TaskStatus {
  OPEN        @map("open")
  IN_PROGRESS @map("in_progress")
  DONE        @map("done")
  CANCELED    @map("canceled")
}

enum ReviewStatus {
  REQUESTED @map("requested")
  SUBMITTED @map("submitted")
  DISMISSED @map("dismissed")
}

model Workspace {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  timezone      String         @default("UTC")
  locale        String         @default("en")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  customers     Customer[]
  appointments  Appointment[]
  messages      Message[]
  workflowRules WorkflowRule[]
  tasks         Task[]
  reviews       Review[]

  @@map("workspace")
}

model User {
  id             String     @id @default(cuid())
  workspaceId    String
  email          String
  name           String
  role           String     @default("owner")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownedCustomers Customer[] @relation("CustomerOwner")
  assignedTasks  Task[]     @relation("TaskAssignee")

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@map("user")
}

model Customer {
  id                String            @id @default(cuid())
  workspaceId       String
  ownerId           String?
  firstName         String
  lastName          String?
  email             String?
  phone             String?
  status            CustomerStatus    @default(NEW_LEAD)
  preferredLanguage PreferredLanguage @default(EN)
  source            String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner             User?             @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  appointments      Appointment[]
  messages          Message[]
  tasks             Task[]
  reviews           Review[]

  @@index([workspaceId, status])
  @@index([ownerId])
  @@map("customer")
}

model Appointment {
  id          String            @id @default(cuid())
  workspaceId String
  customerId  String
  startsAt    DateTime
  endsAt      DateTime?
  status      AppointmentStatus @default(SCHEDULED)
  serviceName String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages    Message[]
  reviews     Review[]

  @@index([workspaceId, startsAt])
  @@index([customerId])
  @@map("appointment")
}

model Message {
  id                String           @id @default(cuid())
  workspaceId       String
  customerId        String
  appointmentId     String?
  channel           MessageChannel
  direction         MessageDirection @default(OUTBOUND)
  status            MessageStatus    @default(DRAFT)
  subject           String?
  body              String
  providerMessageId String?
  scheduledAt       DateTime?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment       Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, channel, status])
  @@index([customerId])
  @@index([appointmentId])
  @@map("message")
}

model WorkflowRule {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  trigger     WorkflowTrigger
  action      WorkflowAction
  isActive    Boolean         @default(true)
  config      Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([workspaceId, trigger])
  @@map("workflow_rule")
}

model Task {
  id             String        @id @default(cuid())
  workspaceId    String
  customerId     String?
  workflowRuleId String?
  assigneeId     String?
  title          String
  description    String?
  status         TaskStatus    @default(OPEN)
  dueAt          DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  workflowRule   WorkflowRule? @relation(fields: [workflowRuleId], references: [id], onDelete: SetNull)
  assignee       User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([customerId])
  @@map("task")
}

model Review {
  id            String         @id @default(cuid())
  workspaceId   String
  customerId    String
  appointmentId String?
  status        ReviewStatus   @default(REQUESTED)
  channel       MessageChannel
  rating        Int?
  comment       String?
  externalUrl   String?
  requestedAt   DateTime?
  submittedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([customerId])
  @@map("review")
}
